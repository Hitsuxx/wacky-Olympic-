function StickyCTA() {
  const { t } = useLang();
  const [show, setShow] = useState(true);
  useEffect(() => {
    const finder = document.getElementById("finder");
    if (!finder) return;
    const obs = new IntersectionObserver(([e]) => setShow(!e.isIntersecting), { threshold: 0.08 });
    obs.observe(finder);
    return () => obs.disconnect();
  }, []);
  if (!show) return null;
  return (
    <button
      onClick={() => document.getElementById("finder")?.scrollIntoView({ behavior: "smooth" })}
      className="md:hidden fixed bottom-4 inset-x-4 z-40 inline-flex items-center justify-center gap-2 rounded-full py-3.5 font-bold text-base"
      style={{ background: C.orange, color: "#fff", boxShadow: "0 8px 22px rgba(242,128,59,.45)" }}>
      <Search size={18} /> {t.ctaFind}
    </button>
  );
}


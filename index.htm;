function highlight(text, q) {
  if (!q) return text;
  const i = text.toLowerCase().indexOf(q.toLowerCase());
  if (i === -1) return text;
  return (<>{text.slice(0, i)}<mark>{text.slice(i, i + q.length)}</mark>{text.slice(i + q.length)}</>);
}

function TeamCard({ team, tab, query }) {
  const { t } = useLang();
  const [copied, setCopied] = useState(false);
  const counts = useMemo(() => {
    const c = { STEPS: 0, SRSI: 0, HSSP: 0 };
    team.students.forEach((s) => c[s.program]++);
    return c;
  }, [team]);

  const teamName = `${t.teamWord} ${team.id}`;
  const unit = tab === "boys" ? t.boysUnit : t.girlsUnit;

  const copyTeam = () => {
    const head = tab === "boys" ? t.copyHeadBoys : t.copyHeadGirls;
    const txt = `${head} — ${teamName} (${team.students.length})\n` +
      team.students.map((s) => `• ${s.name} — ${s.program}${s.role ? " — " + (s.role === "Captain" ? t.captainFull : t.viceFull) : ""}`).join("\n");
    const done = () => { setCopied(true); setTimeout(() => setCopied(false), 1800); };
    const fallback = () => {
      const ta = document.createElement("textarea");
      ta.value = txt; document.body.appendChild(ta); ta.select();
      try { document.execCommand("copy"); done(); } catch {}
      document.body.removeChild(ta);
    };
    if (navigator.clipboard?.writeText) navigator.clipboard.writeText(txt).then(done).catch(fallback);
    else fallback();
  };

  return (
    <article className="rounded-3xl overflow-hidden flex flex-col" style={{ background: "#fff", boxShadow: "0 3px 16px rgba(14,42,71,.08)" }}>
      <div className="flex items-center justify-between px-4 sm:px-5 py-3.5" style={{ background: team.color }}>
        <h3 className="font-bold text-white text-lg">{teamName}</h3>
        <span className="text-white text-xs sm:text-sm font-semibold rounded-full px-3 py-1"
          style={{ background: "rgba(255,255,255,.22)" }}>
          {team.students.length} {unit}
        </span>
      </div>
      <div className="flex flex-wrap gap-1.5 px-4 sm:px-5 py-2.5" style={{ background: C.cream }} dir="ltr">
        {["STEPS", "SRSI", "HSSP"].map((p) => (
          <span key={p} className="font-en text-xs font-bold rounded-full px-2.5 py-1"
            style={{ background: PROGRAM_STYLE[p].bg, color: PROGRAM_STYLE[p].fg }}>
            {p} × {counts[p]}
          </span>
        ))}
      </div>
      <ul className="px-4 sm:px-5 py-2 grow">
        {team.students.map((s) => (
          <li key={s.name} className="flex items-center gap-2.5 py-2 text-sm sm:text-[15px]"
            style={{ borderBottom: "1px solid #F1F4F8" }}>
            <span dir="ltr" className="font-en text-[11px] font-bold rounded-md px-1.5 py-0.5 shrink-0 w-12 text-center"
              style={{ background: PROGRAM_STYLE[s.program].bg, color: PROGRAM_STYLE[s.program].fg }}>
              {s.program}
            </span>
            <span dir="ltr" className="font-en grow text-left" style={{ color: C.ink }}>
              {highlight(s.name, query)}
            </span>
            {s.role && (
              <span className="text-[10px] font-bold rounded-full px-2 py-0.5 shrink-0 text-white"
                style={{ background: s.role === "Captain" ? C.orange : C.navy }}>
                {s.role === "Captain" ? t.captain : t.vice}
              </span>
            )}
          </li>
        ))}
      </ul>
      <div className="px-4 sm:px-5 pb-4 pt-1">
        <button onClick={copyTeam}
          className="w-full inline-flex items-center justify-center gap-2 rounded-xl py-2.5 font-semibold text-sm transition-colors"
          style={{ background: copied ? "#E5F6EC" : C.cream, color: copied ? "#177A3E" : C.navy }}>
          {copied ? <Check size={16} /> : <Copy size={16} />} {copied ? t.copied : t.copyBtn}
        </button>
      </div>
    </article>
  );
}

function TeamFinder() {
  const { t } = useLang();
  const [tab, setTab] = useState("boys");
  const [query, setQuery] = useState("");
  const [program, setProgram] = useState("ALL");
  const [teamSel, setTeamSel] = useState("all");

  const source = tab === "boys" ? boysTeams : girlsTeams;
  useEffect(() => { setTeamSel("all"); }, [tab]);

  const filtered = useMemo(() => {
    const q = query.trim().toLowerCase();
    return source
      .filter((tm) => teamSel === "all" || tm.id === Number(teamSel))
      .map((tm) => {
        let students = tm.students;
        if (program !== "ALL") students = students.filter((s) => s.program === program);
        if (q) students = students.filter((s) => s.name.toLowerCase().includes(q));
        return { ...tm, visible: students };
      })
      .filter((tm) => tm.visible.length > 0 || (!q && program === "ALL"));
  }, [source, query, program, teamSel]);

  const visStudents = filtered.reduce((s, tm) => s + tm.visible.length, 0);
  const visPrograms = [...new Set(filtered.flatMap((tm) => tm.visible.map((s) => s.program)))];
  const active = query.trim() || program !== "ALL";

  const tabStyle = (isOn, kind) => ({
    background: isOn ? (kind === "boys" ? C.navy : C.coral) : "#fff",
    color: isOn ? "#fff" : C.navy,
    border: `2px solid ${isOn ? "transparent" : C.creamDark}`,
    boxShadow: isOn ? "0 5px 16px rgba(14,42,71,.22)" : "none",
  });

  return (
    <section id="finder" className="py-14 sm:py-20" style={{ background: C.cream }}>
      <div className="max-w-6xl mx-auto px-4 sm:px-6">
        <Reveal>
          <h2 className="font-extrabold text-center text-2xl sm:text-4xl" style={{ color: C.navy }}>
            {t.finderTitle}
          </h2>
          <p className="text-center mt-2.5 text-sm sm:text-base" style={{ color: C.inkSoft }}>
            {t.finderSub}
          </p>
        </Reveal>

        <Reveal delay={80}>
          <div className="grid grid-cols-2 gap-3 max-w-md mx-auto mt-7" role="tablist" aria-label={t.tabsLabel}>
            <button role="tab" aria-selected={tab === "boys"} onClick={() => setTab("boys")}
              className="rounded-2xl py-3.5 font-bold text-base sm:text-lg transition-all"
              style={tabStyle(tab === "boys", "boys")}>
              {t.tabBoys}
            </button>
            <button role="tab" aria-selected={tab === "girls"} onClick={() => setTab("girls")}
              className="rounded-2xl py-3.5 font-bold text-base sm:text-lg transition-all"
              style={tabStyle(tab === "girls", "girls")}>
              {t.tabGirls}
            </button>
          </div>
        </Reveal>

        <Reveal delay={140}>
          <div className="flex flex-col sm:flex-row gap-3 max-w-3xl mx-auto mt-5">
            <div className="relative grow">
              <Search size={18} className="absolute top-1/2 -translate-y-1/2 pointer-events-none"
                style={{ insetInlineStart: 16, color: C.inkSoft }} />
              <input type="search" value={query} onChange={(e) => setQuery(e.target.value)}
                placeholder={tab === "boys" ? t.searchBoys : t.searchGirls}
                aria-label={t.searchLabel}
                className="w-full rounded-2xl py-3.5 text-sm sm:text-base"
                style={{ background: "#fff", border: `2px solid ${C.creamDark}`, paddingInlineStart: 44, paddingInlineEnd: 16, color: C.ink }} />
            </div>
            <div className="relative">
              <select value={teamSel} onChange={(e) => setTeamSel(e.target.value)} aria-label={t.teamSelLabel}
                className="w-full sm:w-auto appearance-none rounded-2xl py-3.5 font-semibold text-sm sm:text-base cursor-pointer"
                style={{ background: "#fff", border: `2px solid ${C.creamDark}`, color: C.navy, paddingInlineStart: 18, paddingInlineEnd: 42 }}>
                <option value="all">{t.allTeams}</option>
                {source.map((tm) => <option key={tm.id} value={tm.id}>{t.teamWord} {tm.id}</option>)}
              </select>
              <ChevronDown size={17} className="absolute top-1/2 -translate-y-1/2 pointer-events-none"
                style={{ insetInlineEnd: 14, color: C.inkSoft }} />
            </div>
          </div>
          <div className="flex flex-wrap justify-center gap-2 mt-4" dir="ltr">
            {["ALL", "STEPS", "SRSI", "HSSP"].map((p) => (
              <button key={p} onClick={() => setProgram(p)}
                className="rounded-full px-4 py-2 text-sm font-bold transition-all font-en"
                style={{
                  background: program === p ? C.teal : "#fff",
                  color: program === p ? "#fff" : C.inkSoft,
                  border: `2px solid ${program === p ? C.teal : C.creamDark}`,
                }}>
                {p === "ALL" ? t.allPrograms : p}
              </button>
            ))}
          </div>
        </Reveal>

        <div className="flex flex-wrap justify-center gap-x-5 gap-y-1 mt-6 text-xs sm:text-sm font-semibold" style={{ color: C.inkSoft }}>
          <span>{t.sumTeams}: <b style={{ color: C.navy }}>{filtered.length}</b></span>
          <span>{tab === "boys" ? t.sumBoys : t.sumGirls}: <b style={{ color: C.navy }}>{visStudents}</b></span>
          <span dir="ltr" className="font-en">{visPrograms.join(" · ") || "—"}</span>
        </div>

        {filtered.length === 0 ? (
          <div className="text-center mt-12 rounded-3xl py-12 px-6 max-w-md mx-auto" style={{ background: "#fff" }}>
            <p className="font-bold text-lg" style={{ color: C.navy }}>{t.noResults}</p>
            <p className="mt-2 text-sm" style={{ color: C.inkSoft }}>{t.noResultsHint}</p>
          </div>
        ) : (
          <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-5 mt-8">
            {filtered.map((tm) => (
              <TeamCard key={tab + tm.id} team={active ? { ...tm, students: tm.visible } : tm} tab={tab} query={query.trim()} />
            ))}
          </div>
        )}
      </div>
    </section>
  );
}


const Confetti = ({ count = 16 }) => {
  const pieces = useMemo(() =>
    Array.from({ length: count }, (_, i) => ({
      left: `${(i * 61) % 100}%`,
      color: [C.teal, C.orange, C.pink, C.aqua, C.navy][i % 5],
      dur: 7 + (i % 5) * 1.7,
      delay: (i * 0.9) % 8,
      w: 6 + (i % 3) * 3,
    })), [count]);
  return (
    <div className="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      {pieces.map((p, i) => (
        <span key={i} className="confetto"
          style={{ left: p.left, width: p.w, height: p.w * 1.7, background: p.color,
            animationDuration: `${p.dur}s`, animationDelay: `${p.delay}s` }} />
      ))}
    </div>
  );
};

